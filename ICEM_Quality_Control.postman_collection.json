{
	"info": {
		"_postman_id": "b1a2c3d4-e5f6-7890-1234-56789abcdef0",
		"name": "ICEM Quality Control API - Tests Validation",
		"description": "Collection de tests complète pour valider les User Stories (US01 à US05) de l'application ICEM Quality Control.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "US01 - Authentification (Test avec Postman)",
			"item": [
				{
					"name": "1. Connexion (Identifiants Valides)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@icem.tn\",\n    \"password\": \"Icem2026!\",\n    \"returnSecureToken\": true\n}"
						},
						"url": {
							"raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebase_api_key}}",
							"protocol": "https",
							"host": [
								"identitytoolkit",
								"googleapis",
								"com"
							],
							"path": [
								"v1",
								"accounts:signInWithPassword"
							],
							"query": [
								{
									"key": "key",
									"value": "{{firebase_api_key}}"
								}
							]
						},
						"description": "Test de connexion avec des identifiants valides. Copiez le 'idToken' reçu dans la variable d'environnement 'firebase_token' pour les requêtes suivantes."
					},
					"response": []
				},
				{
					"name": "2. Vérifier le rôle de l'utilisateur (Me)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{firebase_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/me",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"me"
							]
						},
						"description": "Vérifie les informations et le rôle de l'utilisateur connecté."
					},
					"response": []
				}
			]
		},
		{
			"name": "US02 & US03 - Gestion des Utilisateurs et Rôles",
			"item": [
				{
					"name": "1. Création d'un utilisateur",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{firebase_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"nouveau.tech@icem.tn\",\n    \"fullName\": \"Nouveau Technicien\",\n    \"username\": \"nouveau_tech\",\n    \"roles\": [\"technician\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users"
							]
						}
					},
					"response": []
				},
				{
					"name": "2. Lister tous les utilisateurs",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{firebase_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users"
							]
						}
					},
					"response": []
				},
				{
					"name": "3. Désactiver un utilisateur",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{firebase_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"isActive\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/users/USER_ID_ICI",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"USER_ID_ICI"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "US04 & US05 - Ordres de Fabrication et Persistance",
			"item": [
				{
					"name": "1. Création d'un ordre",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{firebase_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderNumber\": \"OF-POSTMAN-001\",\n    \"cableId\": \"CAB-123\",\n    \"quantity\": 50,\n    \"status\": \"En attente\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/orders",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"orders"
							]
						}
					},
					"response": []
