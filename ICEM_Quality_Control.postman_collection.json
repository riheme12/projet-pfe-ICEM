				{
					"name": "2. Consultation des ordres (avec persistance)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{firebase_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/orders?limit=10",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"orders"
							],
							"query": [
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					},
					"response": []
